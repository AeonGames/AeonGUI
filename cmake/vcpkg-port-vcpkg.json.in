{
  "name": "aeongui",
  "version": "@PROJECT_VERSION@",
  "description": "Cross-platform C++ SVG DOM and rendering library for game UI",
  "homepage": "https://github.com/AeonGames/AeonGUI",
  "license": "Apache-2.0",
  "dependencies": [
    "cairo",
    "pango",
    "fontconfig",
    "freetype",
    "harfbuzz",
    "libxml2",
    "zlib",
    "libpng",
    "libjpeg-turbo",
    "pkgconf"
  ]
}
