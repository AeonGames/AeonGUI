{
  "name": "aeongui",
  "version": "@PROJECT_VERSION@",
  "description": "Cross-platform C++ SVG DOM and rendering library for game UI",
  "homepage": "https://github.com/AeonGames/AeonGUI",
  "license": "Apache-2.0",
  "dependencies": [
    "fontconfig",
    "freetype",
    "harfbuzz",
    "libxml2",
    "zlib",
    "libpng",
    "libjpeg-turbo",
    "pkgconf",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": ["cairo"],
  "features": {
    "cairo": {
      "description": "Use Cairo/Pango rendering backend",
      "dependencies": ["cairo", "pango"]
    },
    "skia": {
      "description": "Use Skia rendering backend",
      "dependencies": ["skia"]
    }
  }
}
