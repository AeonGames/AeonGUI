vcpkg_from_git(
    OUT_SOURCE_PATH SOURCE_PATH
    URL https://github.com/AeonGames/AeonGUI.git
    REF @GIT_COMMIT_HASH@
)

# Cairo and Skia backends are mutually exclusive
if("cairo" IN_LIST FEATURES AND "skia" IN_LIST FEATURES)
    message(FATAL_ERROR "Features 'cairo' and 'skia' are mutually exclusive. Select only one backend.")
elseif("skia" IN_LIST FEATURES)
    set(AEONGUI_BACKEND Skia)
else()
    set(AEONGUI_BACKEND Cairo)
endif()

vcpkg_cmake_configure(
    SOURCE_PATH "${SOURCE_PATH}"
    OPTIONS
        -DAEONGUI_BACKEND=${AEONGUI_BACKEND}
        -DBUILD_UNIT_TESTS=OFF
)

vcpkg_cmake_build()
vcpkg_cmake_install()
vcpkg_cmake_config_fixup(PACKAGE_NAME aeongui CONFIG_PATH share/aeongui)

file(REMOVE_RECURSE "${CURRENT_PACKAGES_DIR}/debug/include")
file(REMOVE_RECURSE "${CURRENT_PACKAGES_DIR}/debug/share")

vcpkg_install_copyright(FILE_LIST "${SOURCE_PATH}/LICENSE")
